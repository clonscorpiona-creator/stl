<aside class="main-sidebar">
  <nav class="sidebar-nav">
    <a href="/" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'active' : '' %>">
      <span class="link-icon">&#8962;</span>
      <span class="link-text">Главная</span>
    </a>
    <a href="/portfolio" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === '/portfolio' ? 'active' : '' %>">
      <span class="link-icon">&#9638;</span>
      <span class="link-text">Портфолио</span>
    </a>
    <a href="/chat" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/chat') ? 'active' : '' %>">
      <span class="link-icon">&#9993;</span>
      <span class="link-text">Чат</span>
    </a>
    <% if (typeof user !== 'undefined' && user) { %>
    <a href="/profile" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === '/profile' ? 'active' : '' %>">
      <span class="link-icon">&#9786;</span>
      <span class="link-text">Профиль</span>
    </a>
    <% } %>
  </nav>
</aside>
