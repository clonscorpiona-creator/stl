<%
  const layoutFile = 'layout-3';
  const errorMsg = typeof error !== 'undefined' && error ? `<div class="alert alert-error">${error}</div>` : '';
  const successMsg = typeof success !== 'undefined' && success ? `<div class="alert alert-success">${success}</div>` : '';
%>
<%- include('../layouts/' + layoutFile, {
  title: 'Регистрация',
  user: null,
  body: `
    <div class="auth-container">
      <h1>Регистрация в STL</h1>

      ${errorMsg}
      ${successMsg}

      <form class="auth-form" action="/auth/register" method="POST">
        <input type="hidden" name="_csrf" value="${typeof csrfToken !== 'undefined' ? csrfToken : ''}">
        <div class="form-group">
          <label for="username">Имя пользователя</label>
          <input type="text" id="username" name="username" required placeholder="Как к вам обращаться">
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com">
        </div>

        <div class="form-group">
          <label for="password">Пароль</label>
          <input type="password" id="password" name="password" required placeholder="Минимум 6 символов" minlength="6">
        </div>

        <button type="submit" class="btn btn-primary btn-full">Зарегистрироваться</button>
      </form>

      <p class="auth-link">
        Уже есть аккаунт? <a href="/auth/login">Войти</a>
      </p>
    </div>
  `
}) %>
