<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title><%= title %> - STL</title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/layouts/layout-1.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link rel="stylesheet" href="/css/pjax.css">
  <link rel="stylesheet" href="/css/portfolio.css">
</head>
<body class="layout-1">
  <%- include('../partials/header', { user: user || null }) %>

  <div class="layout-container">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
      <%- body %>
    </main>
  </div>

  <%- include('../partials/footer') %>

  <!-- Dynamic Modules (for future use) -->

  <div id="pjax-progress"></div>
  <script src="/js/main.js"></script>
  <script src="/js/layout-switcher.js"></script>
  <script src="/js/pjax.js"></script>
  <script>
    window.currentLayout = '<%= currentLayout %>';
  </script>
</body>
</html>
