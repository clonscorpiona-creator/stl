<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - STL</title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/layouts/layout-5.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link rel="stylesheet" href="/css/portfolio.css">
</head>
<body class="layout-5">
  <%- include('../partials/header', { user: user || null }) %>
  <div class="compact-header">
    <a href="/" class="logo">STL</a>
    <nav class="compact-nav">
      <a href="/">Главная</a>
      <a href="/portfolio">Портфолио</a>
      <a href="/chat">Чат</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile">Профиль</a>
        <a href="/auth/logout" class="btn-logout">Выход</a>
      <% } else { %>
        <a href="/auth/login">Вход</a>
      <% } %>
    </nav>
  </div>

  <main class="main-content compact-main">
    <%- body %>
  </main>

  <div class="compact-footer">
    <span>STL &copy; <%= new Date().getFullYear() %></span>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/layout-switcher.js"></script>
  <script>
    window.currentLayout = '<%= currentLayout %>';
  </script>
</body>
</html>
