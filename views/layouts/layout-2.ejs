<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - STL</title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/layouts/layout-2.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link rel="stylesheet" href="/css/portfolio.css">
</head>
<body class="layout-2">
  <%- include('../partials/header', { user: user || null }) %>

  <div class="layout-container layout-2-container">
    <main class="main-content main-content-wide">
      <%- body %>
    </main>

    <aside class="right-sidebar">
      <div class="sidebar-block">
        <h3>Навигация</h3>
        <nav class="side-nav">
          <a href="/">Главная</a>
          <a href="/portfolio">Портфолио</a>
          <a href="/chat">Чат</a>
          <% if (typeof user !== 'undefined' && user) { %>
            <a href="/profile">Профиль</a>
            <a href="/auth/logout">Выход</a>
          <% } else { %>
            <a href="/auth/login">Вход</a>
            <a href="/auth/register">Регистрация</a>
          <% } %>
        </nav>
      </div>
    </aside>
  </div>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>
  <script src="/js/layout-switcher.js"></script>
  <script>
    window.currentLayout = '<%= currentLayout %>';
  </script>
</body>
</html>
