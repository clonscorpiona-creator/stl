<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - STL</title>
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/layouts/layout-4.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link rel="stylesheet" href="/css/portfolio.css">
</head>
<body class="layout-4">
  <%- include('../partials/header', { user: user || null }) %>

  <div class="layout-container layout-grid">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
      <div class="grid-wrapper">
        <%- body %>
      </div>
    </main>
  </div>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>
  <script src="/js/layout-switcher.js"></script>
  <script>
    window.currentLayout = '<%= currentLayout %>';
  </script>
</body>
</html>
